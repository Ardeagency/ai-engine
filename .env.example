# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_JWT_SECRET=<your-jwt-secret>

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.io,https://www.yourdomain.io

# ── Internal security ────────────────────────────────────────────────────────
INTERNAL_API_KEY=cp_internal_<random>
INTERNAL_WEBHOOK_SECRET=whsec_<random>

# ── Anthropic (LLM provider for Vera) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenClaw ─────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=<your-openclaw-token>
OPENCLAW_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
OPENCLAW_WORKSPACES_DIR=/root/ai-engine/workspaces
OPENCLAW_TIMEOUT_MS=120000

# ── Multi-tenant: Hetzner Provisioning ───────────────────────────────────────
# Token de la API de Hetzner (Hetzner Cloud → Project → API Tokens)
HETZNER_API_TOKEN=<your-hetzner-api-token>

# Location donde crear los org-servers
# Opciones: nbg1, fsn1, hel1, ash, hil, sin
HETZNER_LOCATION=nbg1

# URL publica del control plane — debe ser accesible desde los org-servers
AI_ENGINE_URL=http://<your-ai-engine-ip>:3000

# ── Session budgets (optional) ───────────────────────────────────────────────
# SESSION_TTL_MS=1800000
# SESSION_TOKEN_BUDGET=10000
# SESSION_TOOL_BUDGET=50

# ── Feature flags ─────────────────────────────────────────────────────────────
# SCRAPER_ENABLED=true
# SCRAPER_INTERVAL_MINUTES=45
# JOB_WORKER_ENABLED=true
# ORG_SYNC_ENABLED=true
# ORG_SYNC_INTERVAL_MS=300000
